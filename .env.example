# =============================================================================
# GEDCA — variables d'environnement
# Copier en .env et adapter. Ne JAMAIS committer .env.
# =============================================================================

# Mode de déploiement : 'saas' (multi-tenant cloud) ou 'onprem' (mono-tenant Docker)
DEPLOYMENT_MODE=onprem

# --- Base de données PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gedca
POSTGRES_USER=gedca
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://gedca:change_me_strong_password@postgres:5432/gedca

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Sécurité ---
# Secret de signature JWT (à régénérer avec : openssl rand -hex 32)
JWT_SECRET=change_me_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Clé maître de chiffrement des documents (AES-256, 32 octets en base64)
# À générer : python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY=change_me_32_random_bytes_base64

# --- Stockage fichiers ---
STORAGE_PATH=/app/storage
QUARANTINE_PATH=/app/storage/quarantaine

# --- IA ---
# 'anthropic' (cloud) ou 'ollama' (on-premise)
AI_PROVIDER=ollama

# Si AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
VOYAGE_API_KEY=
EMBEDDING_MODEL_CLOUD=voyage-multilingual-2

# Si AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL_LOCAL=intfloat/multilingual-e5-large

# --- Watcher dossier surveillé (ingestion) ---
WATCH_FOLDER=/app/storage/inbox

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api

# --- Logs ---
LOG_LEVEL=INFO
