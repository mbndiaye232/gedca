# =============================================================================
# GEDCA — variables d'environnement
# Copier en .env et adapter. Ne JAMAIS committer .env.
# =============================================================================

# Mode de déploiement : 'saas' (multi-tenant cloud) ou 'onprem' (mono-tenant Docker)
DEPLOYMENT_MODE=onprem

# --- Base de données PostgreSQL ---
# En SaaS : URL fournie par Render (Managed PostgreSQL avec pgvector activé).
# En on-prem : pointe sur le conteneur postgres du docker-compose.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gedca
POSTGRES_USER=gedca
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://gedca:change_me_strong_password@postgres:5432/gedca

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Sécurité / Auth ---
# Secret de signature JWT (à régénérer avec : openssl rand -hex 32)
JWT_SECRET=change_me_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# Origines autorisées pour CORS, séparées par des virgules
ALLOWED_ORIGINS=http://localhost:5173

# Clé maître de chiffrement des documents (AES-256, 32 octets en base64)
# À générer : python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY=change_me_32_random_bytes_base64

# --- Stockage fichiers ---
# Backend de stockage : 'local' (disque, dev / on-prem) ou 'r2' (Cloudflare R2).
# ⚠️ Sur Render le disque est ÉPHÉMÈRE : utiliser 'r2' en production cloud.
STORAGE_BACKEND=local
# Racine du stockage chiffré (mode local) ; fichiers rangés en {STORAGE_ROOT}/{tenant_id}/{checksum}.enc
STORAGE_ROOT=/app/storage
QUARANTINE_PATH=/app/storage/quarantaine
# Dossier temporaire utilisé par le worker pour le déchiffrement à la volée (OCR, conversion)
WORKER_TEMP_DIR=/app/storage/tmp
# Taille max d'un upload (en Mo)
MAX_UPLOAD_SIZE_MB=100

# --- Cloudflare R2 (requis si STORAGE_BACKEND=r2) ---
# R2 est compatible S3. Créer un bucket + un token API R2 (lecture/écriture).
# L'endpoint est dérivé de l'Account ID, sauf si R2_ENDPOINT est fourni.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=softgedcap-documents
# Optionnel — endpoint S3 explicite (sinon https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com)
R2_ENDPOINT=

# --- IA ---
# 'anthropic' (cloud) ou 'ollama' (on-premise)
AI_PROVIDER=ollama

# Si AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
VOYAGE_API_KEY=
EMBEDDING_MODEL_CLOUD=voyage-3

# Si AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBEDDING_MODEL_LOCAL=intfloat/multilingual-e5-large

# --- Worker Celery ---
CELERY_WORKER_CONCURRENCY=2
# Intervalle de polling IMAP en minutes (Celery Beat)
IMAP_POLL_INTERVAL_MIN=15
# TTL (jours) des pièces jointes IMAP en staging avant purge automatique
IMAP_STAGING_TTL_DAYS=30

# --- Watcher dossier surveillé (ingestion) ---
# Racine du dossier observé. En SaaS multi-tenant, structure : {WATCHER_ROOT}/{tenant_id}/
WATCHER_ROOT=/app/storage/inbox
# Activer le watcher (désactivé par défaut en SaaS — à activer par déploiement)
WATCHER_ENABLED=false
# Forcer le mode polling (utile si inotify indisponible, ex. volume NFS)
WATCHER_FORCE_POLLING=false

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api

# --- Logs ---
LOG_LEVEL=INFO
